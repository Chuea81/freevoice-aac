# APK Signing Configuration
# Copy this file to .env.apk and fill in actual values
# NEVER commit the real .env.apk file

# Keystore password (generated during keystore creation)
KEYSTORE_PASSWORD=your_keystore_password_here

# Key password (usually same as keystore password)
KEY_PASSWORD=your_key_password_here

# Keystore path (relative to project root)
KEYSTORE_PATH=.keystore/freevoice.jks

# Key alias (identifier for the key in the keystore)
KEY_ALIAS=freevoice
